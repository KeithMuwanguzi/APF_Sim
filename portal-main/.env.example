# Django Backend API Configuration
# Used for: Authentication, Applications, Payments, Member Management
VITE_API_URL=http://localhost:8000

# Strapi CMS API Configuration
# Used for: Events, News, Leadership, Benefits, FAQs, Partners, Page Content
VITE_CMS_URL=http://localhost:1337

# Instructions:
# 1. Copy this file to .env
# 2. Replace localhost URLs with production URLs when deploying
# 3. Never commit .env file to git
